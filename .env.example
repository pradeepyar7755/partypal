# ============================================
# PartyPal Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to GitHub

# Google API Key (used for Maps, Places, and Gemini AI)
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=AIzaSy-REPLACE_WITH_YOUR_KEY

# App URL (change to your domain in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DOMAIN=partypal.social

# WhatsApp Cloud API (Emcee chatbot)
# Set up at: https://developers.facebook.com/apps/947468517937394
WHATSAPP_ACCESS_TOKEN=          # Permanent System User token
WHATSAPP_PHONE_ID=              # Phone Number ID from Meta dashboard
WHATSAPP_VERIFY_TOKEN=          # Custom string for webhook verification
WHATSAPP_APP_SECRET=            # App secret for payload signature validation
